# 🚀 Instaup 프론트엔드 환경변수
# Backend API URL (Railway 배포된 백엔드)
VITE_API_BASE_URL=https://instaup-production.up.railway.app
VITE_BACKEND_API_URL=https://instaup-production.up.railway.app

# API 키 (개발용)
VITE_API_KEY=demo_key

# 결제 시스템 (개발/테스트용)
VITE_TOSSPAY_CLIENT_KEY=test_ck_PLACEHOLDER
VITE_KAKAOPAY_CID=test_cid

# 환경 구분
VITE_NODE_ENV=production

# CORS 확인용
VITE_FRONTEND_URL=https://instaup-clean.netlify.app
