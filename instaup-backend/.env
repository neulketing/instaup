# 🔐 Instaup 백엔드 환경변수

# JWT 시크릿 키 (프로덕션에서는 반드시 변경)
JWT_SECRET=instaup_dev_secret_key_very_long_string_for_security_2024

# 데이터베이스 (Railway에서 자동 설정됨)
DATABASE_URL="postgresql://user:password@localhost:5432/instaup_dev?schema=public"

# CORS 설정
CORS_ORIGIN=http://localhost:5173

# 서버 설정
PORT=3001
NODE_ENV=development

# 추천인 시스템 설정
REFERRAL_SIGNUP_BONUS=10000
REFERRAL_COMMISSION_RATE_L1=0.10
REFERRAL_COMMISSION_RATE_L2=0.05
REFERRAL_COMMISSION_RATE_L3=0.03

# 결제 API (개발용)
TOSSPAY_CLIENT_SECRET=test_sk_PLACEHOLDER
KAKAOPAY_ADMIN_KEY=dev_admin_key
